{
  "name": "matterbridge-ecovacs",
  "version": "0.1.64",
  "description": "Matterbridge plugin to bridge Ecovacs Deebot robot vacuums into Apple Home via Matter",
  "author": "Michele Galanti",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "matterbridge",
    "matterbridge-plugin",
    "matter",
    "ecovacs",
    "deebot",
    "vacuum"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "files": [
    "dist",
    "matterbridge-ecovacs.schema.json",
    "README.md"
  ],
  "dependencies": {
    "ecovacs-deebot": "0.9.6-beta.12",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "matterbridge": {
    "type": "DynamicPlatform"
  },
  "homepage": "https://github.com/bubez81/matterbridge-ecovacs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bubez81/matterbridge-ecovacs.git"
  },
  "bugs": {
    "url": "https://github.com/bubez81/matterbridge-ecovacs/issues"
  }
}
